{
  "name": "zoom-flodesk-redirect",
  "version": "1.0.0",
  "private": true,
  "description": "Redirects event registrants to their personalized Zoom join link, looked up from Flodesk; also serves B2B partner QR redirects and one-click reserve flows.",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@vercel/edge-config": "^1.4.0"
  },
  "devDependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "googleapis": "^173.0.0",
    "qrcode": "^1.5.4"
  },
  "scripts": {
    "generate-qr": "node scripts/generate-qr-codes.js",
    "qr-check": "./scripts/run-qr-check.sh",
    "cycle": "node scripts/current-event.js --verbose",
    "draft-check": "node scripts/generate-gmail-drafts.js",
    "draft-gen": "node scripts/generate-gmail-drafts.js --create"
  }
}
