{
  "rewrites": [
    {
      "source": "/reserve/:event",
      "destination": "/api/reserve?event=:event"
    },
    {
      "source": "/reserve",
      "destination": "/api/reserve"
    },
    {
      "source": "/partner/:slug",
      "destination": "/api/partner?slug=:slug"
    },
    {
      "source": "/:event",
      "destination": "/api/join?event=:event"
    }
  ]
}
